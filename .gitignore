## Ignore Visual Studio temporary files, build results, and files generated by popular IDEs.
# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Log]s/
[Log]g/

# Visual Studio files
.vs/
*.user
*.userosscache
*.sln.docstates

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Rider / IntelliJ
.idea/
*.iws
*.idea

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Mono / Xamarin
*.userprefs
*.usertasks

# ReSharper is a tool for Visual Studio
_ReSharper*/
*.[Re]Sharper
*.DotSettings.user

# Database file
*.db
*.sqlite
*.sqlite3

# OS metadata
.DS_Store
Thumbs.db

# Docker
.dockerignore

# AppSettings files secrets (keep appsettings.json, ignore custom secrets)
secrets.json
appsettings.local.json
